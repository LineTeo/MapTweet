    }).setView([<%= t.getLatitude() %>, <%= t.getLongitude() %>], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(m);
    L.marker([<%= t.getLatitude() %>, <%= t.getLongitude() %>]).addTo(m);
  })();
<%
      }
    }
  }
%>
</script>

</body>
</html>
